{
  "name": "focus-study-app",
  "version": "1.0.0",
  "description": "A vintage Pomodoro & music study app",
  "main": "main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "electron .",
    "dist": "electron-builder"
  },
  "keywords": [],
  "author": "khoahdinh",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.khoahdinh.inthemoodforstudy",
    "productName": "In The Mood For Study",
    "files": [
      "main.js",
      "renderer.js",
      "index.html",
      "style.css",
      "assets/**/*",
      "fontawesome/**/*"
    ],
    "win": {
      "target": "nsis"
